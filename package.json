{
  "name": "demo-reel",
  "version": "0.7.5",
  "description": "Create demo videos from web apps using Playwright",
  "keywords": [
    "automation",
    "cli",
    "demo",
    "playwright",
    "video"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "demo-reel": "bin/demo-reel.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "helpers",
    ".claude-plugin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./helpers/*": "./helpers/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage:badge": "node scripts/write-coverage-badge.mjs coverage/coverage-summary.json .github/badges/coverage.json",
    "security:audit": "pnpm audit --json --prod > audit.json || true",
    "security:badge": "node scripts/write-security-badge.mjs audit.json .github/badges/security.json",
    "lint": "oxlint .",
    "lint:ci": "oxlint .",
    "format": "oxfmt . --write",
    "format:ci": "oxfmt . --check",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "glob": "^13.0.6",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "openai": "^4.0.0 || ^5.0.0",
    "playwright": "^1.58.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
