{
  "name": "demo-reel",
  "version": "0.1.4",
  "description": "Create demo videos from web apps using Playwright",
  "keywords": [
    "automation",
    "cli",
    "demo",
    "playwright",
    "video"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "demo-reel": "dist/cli.js",
    "demo-reel-crawl": "dist/script/crawl-cli.js",
    "demo-reel-voice": "dist/script/voice-cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "demo-reel": "link:../../.local/share/pnpm/global/5/node_modules/demo-reel",
    "ffmpeg-static": "^5.2.0",
    "glob": "^13.0.6",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "@vitest/ui": "^4.1.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "playwright": "^1.58.0",
    "openai": "^4.0.0 || ^5.0.0"
  },
